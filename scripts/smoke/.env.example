# Copy to .env and fill in your DeepSeek (or other OpenAI-compat)
# credentials. compose.yml + run.sh both honour this file via the
# default docker compose env-file pickup.

# Host directory that holds the runner's state, agent binaries cache,
# and downloaded agent bundles. Must be an ABSOLUTE path because the
# runner bind-mounts it into its own container at the same path so
# the runner and the docker daemon agree on what `/.../bundle/<sha>`
# means. Defaulted by run.sh to <repo-root>/data/smoke.
HANGRIX_SMOKE_STATE_DIR=/REPLACE_WITH_ABSOLUTE_PATH/data/smoke

# OpenAI-compat provider details. base_url is what the proxy adapter
# prepends `/v1/chat/completions` to.
LLM_API_KEY=sk-REPLACE
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-pro

# Admin user that run.sh creates if no users exist yet.
ADMIN_USER=smoke-admin
ADMIN_EMAIL=smoke-admin@example.com
ADMIN_PASSWORD=smoke-pass-1234
